// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// ============================================================
// FDM — Friends of the Divine Mercy
// Community Management System — Prisma Schema v10
// ============================================================

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// [1] LOOKUP / REFERENCE TABLES
// ============================================================

model Role {
  id          Int     @id @default(autoincrement())
  key         String  @unique @db.VarChar(50)
  name        String  @db.VarChar(100)
  scope       String  @default("global") @db.VarChar(20)
  description String? @db.VarChar(255)
  is_active   Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user_roles     UserRole[]
  @@index([created_at])
  @@map("roles")
}

model MinistryType {
  id          Int     @id @default(autoincrement())
  key         String  @unique @db.VarChar(50)
  name        String  @db.VarChar(100)
  description String? @db.VarChar(255)
  is_active   Boolean @default(true)

  created_at DateTime @default(now())
  created_by Int?

  updated_at DateTime @updatedAt
  updated_by Int?

  deleted_at DateTime?
  deleted_by Int?

  creator         User?          @relation("MinistryTypeCreator", fields: [created_by], references: [id])
  updated_by_user User?          @relation("MinistryTypeUpdatedBy", fields: [updated_by], references: [id])
  deleted_by_user User?          @relation("MinistryTypeDeletedBy", fields: [deleted_by], references: [id])
  ministry_heads  MinistryHead[]

  @@index([created_at])
  @@map("ministry_types")
}

model EventType {
  id          Int     @id @default(autoincrement())
  key         String  @unique @db.VarChar(50)
  name        String  @db.VarChar(100)
  description String? @db.VarChar(255)
  is_active   Boolean @default(true)

  created_at DateTime @default(now())
  created_by Int?

  updated_at DateTime @updatedAt
  updated_by Int?

  deleted_at DateTime?
  deleted_by Int?

  creator         User?   @relation("EventTypeCreator", fields: [created_by], references: [id])
  updated_by_user User?   @relation("EventTypeUpdatedBy", fields: [updated_by], references: [id])
  deleted_by_user User?   @relation("EventTypeDeletedBy", fields: [deleted_by], references: [id])
  events          Event[]

  @@index([created_at])
  @@map("event_types")
}

// ============================================================
// [2] CORE ENTITY TABLES
// ============================================================

model User {
  id                   Int       @id @default(autoincrement())
  auth_id              String?   @unique @db.VarChar(255)
  first_name           String    @db.VarChar(100)
  last_name            String    @db.VarChar(100)
  email                String?   @unique @db.VarChar(255)
  contact_number       String?   @db.VarChar(20)
  account_status       String    @default("pending") @db.VarChar(20)
  birthday             DateTime? @db.Date
  address              String?
  photo_url            String?   @db.VarChar(500)
  is_qr_only           Boolean   @default(false)
  member_qr            String?   @db.VarChar(500)
  qr_generated_at      DateTime?
  qr_regenerated_count Int       @default(0)

  is_temp_password Boolean  @default(false)
  created_at       DateTime @default(now())
  created_by       Int?
  updated_at       DateTime @updatedAt
  updated_by       Int?

  deactivated_at           DateTime?
  deactivated_by           Int?
  activation_email_sent_at DateTime?
  activation_email_resent  Int       @default(0)

  creator           User?  @relation("UserCreatedBy", fields: [created_by], references: [id])
  users_created     User[] @relation("UserCreatedBy")
  users_updated     User[] @relation("UserUpdatedBy")
  updated_by_user   User?  @relation("UserUpdatedBy", fields: [updated_by], references: [id])
  deactivator       User?  @relation("UserDeactivator", fields: [deactivated_by], references: [id])
  deactivated_users User[] @relation("UserDeactivator")

  user_roles       UserRole[]       @relation("UserRoles")
  assigned_roles   UserRole[]       @relation("AssignedBy")
  user_chapters    UserChapter[]
  ministry_members MinistryMember[]
  cluster_members  ClusterMember[]

  attendance         Attendance[]
  events_created     Event[]        @relation("EventCreatedBy")
  events_updated     Event[]        @relation("EventUpdatedBy")
  events_deleted     Event[]        @relation("EventDeletedBy")
  guest_logs_encoded GuestLog[]     @relation("EncodedBy")
  guest_logs_linked  GuestLog[]     @relation("LinkedUser")

  enthronements_contact   EnthronementRecord[] @relation("ContactMember")
  enthronements_performed EnthronementRecord[] @relation("EnthronedBy")
  enthronements_recorded  EnthronementRecord[] @relation("RecordedBy")

  finance_records FinanceRecord[]
  announcements   Announcement[]

  ministry_types_created MinistryType[] @relation("MinistryTypeCreator")
  ministry_types_updated MinistryType[] @relation("MinistryTypeUpdatedBy")
  ministry_types_deleted MinistryType[] @relation("MinistryTypeDeletedBy")
  event_types_created    EventType[]    @relation("EventTypeCreator")
  event_types_updated    EventType[]    @relation("EventTypeUpdatedBy")
  event_types_deleted    EventType[]    @relation("EventTypeDeletedBy")
  chapters_created       Chapter[]      @relation("ChapterCreator")
  chapters_updated       Chapter[]      @relation("ChapterUpdatedBy")
  chapters_deleted       Chapter[]      @relation("ChapterDeletedBy")
  clusters_created       Cluster[]      @relation("ClusterCreator")
  clusters_updated       Cluster[]      @relation("ClusterUpdatedBy")
  clusters_deleted       Cluster[]      @relation("ClusterDeletedBy")

  ministry_heads_updated MinistryHead[] @relation("MinistryHeadUpdater")
  ministry_heads_deleted MinistryHead[] @relation("MinistryHeadDeleter")

  @@index([auth_id])
  @@index([first_name])
  @@index([last_name])
  @@index([email])
  @@index([contact_number])
  @@index([created_at])
  @@map("users")
}

model Chapter {
  id              Int     @id @default(autoincrement())
  name            String  @unique @db.VarChar(100)
  fellowship_day  String? @db.VarChar(20)
  region          String  @db.VarChar(100)
  region_code     String? @db.VarChar(20)
  province        String  @db.VarChar(100)
  province_code   String? @db.VarChar(20)
  city            String  @db.VarChar(100)
  city_code       String? @db.VarChar(20)
  barangay        String  @db.VarChar(100)
  barangay_code   String? @db.VarChar(20)
  street          String? @db.VarChar(255)
  google_maps_url String? @db.VarChar(500)
  landmark        String? @db.VarChar(255)
  is_active       Boolean @default(true)

  created_at DateTime @default(now())
  created_by Int?

  updated_at DateTime @updatedAt
  updated_by Int?

  deleted_at DateTime?
  deleted_by Int?

  creator         User?           @relation("ChapterCreator", fields: [created_by], references: [id])
  updated_by_user User?           @relation("ChapterUpdatedBy", fields: [updated_by], references: [id])
  deleted_by_user User?           @relation("ChapterDeletedBy", fields: [deleted_by], references: [id])
  ministry_heads  MinistryHead[]
  clusters        Cluster[]
  user_roles      UserRole[]
  user_chapters   UserChapter[]
  events          Event[]
  guest_logs      GuestLog[]
  finance_records FinanceRecord[]
  announcements   Announcement[]

  @@index([region])
  @@index([province])
  @@index([city])
  @@index([created_at])
  @@map("chapters")
}

model MinistryHead {
  id               Int @id @default(autoincrement())
  chapter_id       Int
  ministry_type_id Int

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  updated_by Int?
  deleted_at DateTime?
  deleted_by Int?

  chapter       Chapter      @relation(fields: [chapter_id], references: [id])
  ministry_type MinistryType @relation(fields: [ministry_type_id], references: [id])

  updater User? @relation("MinistryHeadUpdater", fields: [updated_by], references: [id])
  deleter User? @relation("MinistryHeadDeleter", fields: [deleted_by], references: [id])

  user_roles       UserRole[]
  ministry_members MinistryMember[]

  @@unique([chapter_id, ministry_type_id])
  @@index([chapter_id])
  @@index([ministry_type_id])
  @@map("ministry_heads")
}

model Cluster {
  id              Int     @id @default(autoincrement())
  name            String  @db.VarChar(100)
  chapter_id      Int
  street          String? @db.VarChar(255)
  google_maps_url String? @db.VarChar(500)
  landmark        String? @db.VarChar(255)

  created_at DateTime @default(now())
  created_by Int?

  updated_at DateTime @updatedAt
  updated_by Int?

  deleted_at DateTime?
  deleted_by Int?

  chapter         Chapter @relation(fields: [chapter_id], references: [id])
  creator         User?   @relation("ClusterCreator", fields: [created_by], references: [id])
  updated_by_user User?   @relation("ClusterUpdatedBy", fields: [updated_by], references: [id])
  deleted_by_user User?   @relation("ClusterDeletedBy", fields: [deleted_by], references: [id])

  user_roles      UserRole[]
  cluster_members ClusterMember[]
  enthronements   EnthronementRecord[]

  @@unique([name, chapter_id])
  @@index([chapter_id])
  @@index([created_at])
  @@map("clusters")
}

model Event {
  id            Int      @id @default(autoincrement())
  name          String   @db.VarChar(255)
  chapter_id    Int?
  event_type_id Int?
  scope         String   @default("global") @db.VarChar(10)
  event_date DateTime
  location   String? @db.VarChar(255)
  location_url String? @db.VarChar(500)

  qr_enabled    Boolean   @default(false)
  qr_token      String?   @db.VarChar(500)
  qr_expires_at DateTime?
  qr_interval   Int       @default(15)

  created_by Int
  updated_by Int?
  deleted_at DateTime?
  deleted_by Int?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  chapter         Chapter?  @relation(fields: [chapter_id], references: [id])
  event_type      EventType? @relation(fields: [event_type_id], references: [id])
  creator         User      @relation("EventCreatedBy", fields: [created_by], references: [id])
  updated_by_user User?     @relation("EventUpdatedBy", fields: [updated_by], references: [id])
  deleted_by_user User?     @relation("EventDeletedBy", fields: [deleted_by], references: [id])

  attendance Attendance[]
  guest_logs GuestLog[]

  @@index([chapter_id])
  @@index([event_date])
  @@index([created_at])
  @@map("events")
}


// ============================================================
// [3] RELATIONSHIP / JUNCTION TABLES
// ============================================================

model UserRole {
  id               Int       @id @default(autoincrement())
  user_id          Int
  role_id          Int
  chapter_id       Int?
  ministry_head_id Int?
  cluster_id       Int?
  assigned_by      Int?
  assigned_at      DateTime  @default(now())
  is_active        Boolean   @default(true)
  deactivated_at   DateTime?
  access_revoked   Boolean   @default(false)

  user     User          @relation("UserRoles", fields: [user_id], references: [id])
  role     Role          @relation(fields: [role_id], references: [id])
  chapter  Chapter?      @relation(fields: [chapter_id], references: [id])
  ministry MinistryHead? @relation(fields: [ministry_head_id], references: [id])
  cluster  Cluster?      @relation(fields: [cluster_id], references: [id])
  assigner User?         @relation("AssignedBy", fields: [assigned_by], references: [id])

  @@unique([user_id, role_id, chapter_id, ministry_head_id, cluster_id])
  @@index([user_id, is_active])
  @@index([chapter_id])
  @@index([ministry_head_id])
  @@index([cluster_id])
  @@map("user_roles")
}

model MinistryMember {
  id               Int      @id @default(autoincrement())
  user_id          Int
  ministry_head_id Int
  joined_at        DateTime @default(now())

  user     User         @relation(fields: [user_id], references: [id])
  ministry MinistryHead @relation(fields: [ministry_head_id], references: [id])

  @@unique([user_id, ministry_head_id])
  @@index([ministry_head_id])
  @@map("ministry_members")
}

model ClusterMember {
  id             Int      @id @default(autoincrement())
  user_id        Int
  cluster_id     Int
  household_name String?  @db.VarChar(255)
  address        String?
  joined_at      DateTime @default(now())

  user    User    @relation(fields: [user_id], references: [id])
  cluster Cluster @relation(fields: [cluster_id], references: [id])

  @@unique([user_id, cluster_id])
  @@index([cluster_id])
  @@map("cluster_members")
}

model UserChapter {
  id         Int      @id @default(autoincrement())
  user_id    Int
  chapter_id Int
  is_primary Boolean  @default(true)
  joined_at  DateTime @default(now())

  user    User    @relation(fields: [user_id], references: [id])
  chapter Chapter @relation(fields: [chapter_id], references: [id])

  @@unique([user_id, chapter_id])
  @@index([user_id, is_primary])
  @@index([chapter_id])
  @@map("user_chapters")
}

// ============================================================
// [4] TRANSACTION / LOG TABLES
// ============================================================

model Attendance {
  id            Int      @id @default(autoincrement())
  user_id       Int?
  event_id      Int
  method        String   @db.VarChar(20)
  checked_in_at DateTime @default(now())
  updated_at    DateTime @updatedAt

  user       User?      @relation(fields: [user_id], references: [id])
  event      Event      @relation(fields: [event_id], references: [id])
  guest_logs GuestLog[]

  @@unique([user_id, event_id])
  @@index([user_id, event_id])
  @@index([event_id])
  @@map("attendance")
}

model GuestLog {
  id               Int      @id @default(autoincrement())
  first_name       String   @db.VarChar(100)
  last_name        String   @db.VarChar(100)
  email            String   @db.VarChar(255)
  contact_number   String   @db.VarChar(20)
  chapter_id       Int?
  encoded_by       Int
  event_id         Int
  attendance_id    Int
  linked_user_id   Int?
  follow_up_status String   @default("pending") @db.VarChar(30)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  chapter     Chapter?   @relation(fields: [chapter_id], references: [id])
  encoder     User       @relation("EncodedBy", fields: [encoded_by], references: [id])
  event       Event      @relation(fields: [event_id], references: [id])
  attendance  Attendance @relation(fields: [attendance_id], references: [id])
  linked_user User?      @relation("LinkedUser", fields: [linked_user_id], references: [id])

  @@index([event_id])
  @@index([chapter_id])
  @@index([created_at])
  @@map("guest_logs")
}

model EnthronementRecord {
  id                     Int      @id @default(autoincrement())
  cluster_id             Int
  household_name         String   @db.VarChar(255)
  address                String
  contact_member_id      Int
  enthroned_at           DateTime
  enthroned_by           Int
  has_divine_mercy_image Boolean  @default(false)
  donation_amount        Decimal? @db.Decimal(10, 2)
  notes                  String?
  recorded_by            Int
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt

  cluster           Cluster @relation(fields: [cluster_id], references: [id])
  contact_member    User    @relation("ContactMember", fields: [contact_member_id], references: [id])
  enthroned_by_user User    @relation("EnthronedBy", fields: [enthroned_by], references: [id])
  recorder          User    @relation("RecordedBy", fields: [recorded_by], references: [id])

  @@index([cluster_id])
  @@index([created_at])
  @@map("enthronement_records")
}

model FinanceRecord {
  id               Int      @id @default(autoincrement())
  chapter_id       Int
  recorded_by      Int
  type             String   @db.VarChar(10)
  amount           Decimal  @db.Decimal(12, 2)
  description      String
  transaction_date DateTime @db.Date
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  chapter  Chapter @relation(fields: [chapter_id], references: [id])
  recorder User    @relation(fields: [recorded_by], references: [id])

  @@index([chapter_id])
  @@index([transaction_date])
  @@index([created_at])
  @@map("finance_records")
}

model Announcement {
  id           Int       @id @default(autoincrement())
  title        String    @db.VarChar(255)
  content      String
  posted_by    Int
  chapter_id   Int?
  type         String    @db.VarChar(20)
  is_published Boolean   @default(false)
  published_at DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  poster  User     @relation(fields: [posted_by], references: [id])
  chapter Chapter? @relation(fields: [chapter_id], references: [id])

  @@index([chapter_id])
  @@index([created_at])
  @@map("announcements")
}
